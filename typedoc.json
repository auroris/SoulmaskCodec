{
  "$schema": "https://typedoc.org/schema.json",
  "plugin": ["typedoc-plugin-markdown"],
  "entryPoints": [
    "src/wscodec.mjs",
    "src/io.mjs",
    "src/primitives.mjs",
    "src/translations.core.mjs"
  ],
  "out": "./docs",
  "readme": "none",
  "excludePrivate": true,
  "excludeInternal": true,
  "sort": ["source-order"],
  "hideGenerator": true,
  "githubPages": false,
  "gitRevision": "main",
  "intentionallyNotExported": ["_FNameLeaf"]
}
